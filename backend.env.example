# Active Production Profile
SPRING_PROFILES_ACTIVE=prod

# Server Port (Auto-injected by Railway)
PORT=8080

# Database URL and Credentials (Auto-injected by Railway PostgreSQL Plugin)
DATABASE_URL=jdbc:postgresql://<host>:<port>/<dbname>
DB_USERNAME=postgres
DB_PASSWORD=your-db-password-here

# Security Secrets (Generate a secure random key)
JWT_SECRET=your-secure-512bit-jwt-secret-key-here
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS Configuration (Set to your Vercel frontend deployment URL)
CORS_ALLOWED_ORIGINS=https://your-crm-frontend.vercel.app
